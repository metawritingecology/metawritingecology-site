---
// Standalone public 404 surface.
//
// This route is intentionally standalone: it emits no canonical URL and no
// JSON-LD, so it stays a minimal, self-contained not-found response.
// Astro's special 404 route preserves an actual HTTP 404 status in SSR mode.
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Page not found — Meta-Writing Ecology</title>
    <meta name="robots" content="noindex, follow" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  </head>

  <body>
    <main>
      <section>
        <h1>Page not found</h1>

        <p>
          The requested public page could not be found. Continue from Home,
          About, Entry Surfaces, or Thematic Entry Points.
        </p>

        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/about/">About</a></li>
          <li><a href="/surfaces/">Entry Surfaces</a></li>
          <li><a href="/entry-points/">Thematic Entry Points</a></li>
        </ul>
      </section>
    </main>
  </body>
</html>
