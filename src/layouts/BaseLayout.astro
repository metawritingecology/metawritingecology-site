---
import "../styles/global.css";
import PublicSearchModal from "../components/PublicSearchModal.astro";

import SchemaJsonLd from "../components/SchemaJsonLd.astro";
import {
  resolvePublicMetadata,
  buildJsonLd,
  APPROVED_PRODUCTION_ORIGIN
} from "../lib/publicMetadata";

const {
  title: propTitle,
  description: propDescription,
  mainClass: propMainClass
} = Astro.props;

const frontmatter = Astro.props.frontmatter ?? {};

// Presentational-only layout hook (not metadata). Routes that pass no value
// render a bare <main>, exactly as before.
const mainClass = propMainClass ?? frontmatter.mainClass;

// Page-local title/description remain in explicit props or Markdown/MDX
// frontmatter and are NOT rewritten here. Route POLICY (language, canonical,
// indexing, structured data, existing genre) comes from the typed registry.
// Inert authority frontmatter (status, classification, visibility, archive,
// registry, authority, relation, publication, language, …) is never consumed.
const title = propTitle ?? frontmatter.title;
const description = propDescription ?? frontmatter.description;

// Canonical origin comes only from the approved Package C production origin
// path (Astro.site); an arbitrary/preview origin can never enter metadata.
const siteOrigin = (Astro.site ?? new URL(APPROVED_PRODUCTION_ORIGIN)).origin;

// One resolver produces title, HTML meta description, html lang, canonical,
// robots, and the structured-data inputs. The HTML meta description and the
// WebPage JSON-LD description therefore resolve from the same page description.
const metadata = resolvePublicMetadata({
  route: Astro.url.pathname,
  title,
  description,
  siteOrigin
});

const jsonLd = buildJsonLd(metadata, siteOrigin);
---

<html lang={metadata.language}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{metadata.title}</title>

    <meta name="description" content={metadata.description} />

    {metadata.robots && <meta name="robots" content={metadata.robots} />}

    {metadata.canonicalUrl && <link rel="canonical" href={metadata.canonicalUrl} />}

    <link rel="icon" type="image/png" href="/favicon.png" />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />

    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    {jsonLd && <SchemaJsonLd data={jsonLd} />}
  </head>

  <body>
    <header class="site-header">
      <nav class="site-nav">
        <a href="/">Home</a>
        <button
          class="site-search-trigger"
          type="button"
          data-search-modal-trigger
          aria-label="Search public MWE surfaces"
        >
          Search public MWE surfaces
        </button>

        <a href="/about/">About</a>

        <a href="/surfaces/">Entry</a>

        <a href="/atlas/">Atlas</a>

        <a href="/models/">Models</a>

        <a href="/fiction/">Fiction</a>

        <a href="/artistic-research/">Artistic Research</a>

        <a href="/publications/">Publications</a>

        <a href="/ai-readable-knowledge-architecture/">AI Architecture</a>

        <a href="/zh/">中文</a>
      </nav>

      <PublicSearchModal />
    </header>

    <main class={mainClass}>
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        Meta-Writing Ecology is a public-facing orientation surface of a recursive
        linguistic and structural analysis system. This site does not contain the
        full working corpus or a complete applied methodology.
      </p>
    </footer>
  </body>
</html>
