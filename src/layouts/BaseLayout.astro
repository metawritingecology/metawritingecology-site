---
import "../styles/global.css";

const SITE_URL = "https://metawritingecology.org";
const SITE_NAME = "Meta-Writing Ecology";
const DEFAULT_TITLE = "Meta-Writing Ecology";
const DEFAULT_DESCRIPTION =
  "A recursive linguistic system and structural diagnostic framework.";

const frontmatter = Astro.props.frontmatter ?? {};
const title = Astro.props.title ?? frontmatter.title ?? DEFAULT_TITLE;
const description =
  Astro.props.description ?? frontmatter.description ?? DEFAULT_DESCRIPTION;
const lang =
  Astro.props.lang ??
  frontmatter.lang ??
  (Astro.url.pathname.startsWith("/zh/") ? "zh-Hant" : "en");
const canonicalUrl = new URL(Astro.url.pathname, SITE_URL).toString();
const ogLocale = lang === "zh-Hant" ? "zh_TW" : "en_US";
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>

  <body>
    <header class="site-header">
      <nav class="site-nav">
        <a href="/">Home</a>
        <a href="/about/">About</a>
        <a href="/surfaces/">Entry Surfaces</a>
        <a href="/entry-points/">Entry Points</a>
        <a href="/fiction/">Fiction</a>
        <a href="/publications/">Publications</a>
        <a href="/platforms/">Platforms</a>
        <a href="/ai-reading-guide/">AI Reading Guide</a>
        <a href="/ai-readable-knowledge-architecture/">AI Architecture</a>
        <a href="/zh/">中文</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        Meta-Writing Ecology is a public-facing surface of a recursive language system.
        This site does not contain the full working corpus.
      </p>
    </footer>
  </body>
</html>
