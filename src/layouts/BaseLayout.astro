---
import "../styles/global.css";
import PublicSearchModal from "../components/PublicSearchModal.astro";

import SchemaJsonLd from "../components/SchemaJsonLd.astro";

const {
  title: propTitle,
  description: propDescription,
  schemaDescription: propSchemaDescription,
  schemaGenre: propSchemaGenre,
  robots: propRobots,
  mainClass: propMainClass
} = Astro.props;

const frontmatter = Astro.props.frontmatter ?? {};

// Optional, backward-compatible route hooks. Routes that pass neither prop are
// rendered exactly as before: no robots meta, and a bare <main>.
const robots = propRobots ?? frontmatter.robots;
const mainClass = propMainClass ?? frontmatter.mainClass;

const title = propTitle ?? frontmatter.title ?? "Meta-Writing Ecology";
const description =
  propDescription ??
  frontmatter.description ??
  "A recursive linguistic system and structural diagnostic framework.";
const schemaDescription = propSchemaDescription ?? frontmatter.schemaDescription;
const schemaGenre = propSchemaGenre ?? frontmatter.schemaGenre;

const SITE_URL = "https://metawritingecology.org/";

const siteUrl = new URL("/", Astro.site ?? SITE_URL).toString();

const pathname = Astro.url.pathname;

const normalizedPathname =
  pathname === "/" || pathname.endsWith("/") || pathname.includes(".")
    ? pathname
    : `${pathname}/`;

const currentUrl = new URL(normalizedPathname, siteUrl).toString();

type PageSchemaSummary = {
  description: string;
  genre: string;
};

const schemaOverrides: Record<string, PageSchemaSummary> = {
  "/": {
    description:
      "Public orientation surface for Meta-Writing Ecology, a recursive linguistic and structural analysis system.",
    genre: "Public orientation surface"
  },
  "/ai-readable-knowledge-architecture/": {
    description:
      "AI-readable boundary page for public documentation surfaces in Meta-Writing Ecology.",
    genre: "AI-readable boundary page"
  },

  "/application-boundary/": {
    description:
      "Public boundary page for scope limits and non-operational positioning of Meta-Writing Ecology public materials.",
    genre: "Public boundary page"
  },

  "/interpretation-boundaries/": {
    description:
      "Public boundary page for reading, summary, and interpretation limits around Meta-Writing Ecology.",
    genre: "Public boundary page"
  },

  "/llms-boundary/": {
    description:
      "AI-readable boundary page describing the public llms.txt orientation file for Meta-Writing Ecology.",
    genre: "AI-readable boundary page"
  },

  "/surfaces/": {
    description:
      "Public orientation surface for navigating Meta-Writing Ecology entry surfaces without exposing non-public working layers.",
    genre: "Public orientation surface"
  },

  "/models/": {
    description:
      "Classification-aware public navigation for GitHub-visible MWE models and adjacent framework documents.",
    genre: "Classification-aware conceptual navigation"
  },

  "/publications/": {
    description:
      "Source-linked publication, DOI, archive, and citation records for Meta-Writing Ecology.",
    genre: "Publication and citation record"
  },

  "/entry-points/": {
    description:
      "Thematic entry points and source-facing reading orientation for Meta-Writing Ecology.",
    genre: "Thematic reading orientation"
  },

  "/public-records/": {
    description:
      "High-level persistence, citation, discovery, and traversal anchors for Meta-Writing Ecology.",
    genre: "Public-record summary"
  }
};

const pageSchema = schemaOverrides[normalizedPathname] ?? {
  description: "Public orientation surface for Meta-Writing Ecology.",
  genre: "Public orientation surface"
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}#website`,
      name: "Meta-Writing Ecology",
      url: siteUrl,
      description:
        "Public orientation surfaces for Meta-Writing Ecology, a recursive linguistic and structural analysis system."
    },
    {
      "@type": "WebPage",
      "@id": `${currentUrl}#webpage`,
      name: title,
      url: currentUrl,
      description: schemaDescription ?? pageSchema.description,
      genre: schemaGenre ?? pageSchema.genre,
      isPartOf: {
        "@id": `${siteUrl}#website`
      }
    }
  ]
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>

    <meta name="description" content={description} />

    {robots && <meta name="robots" content={robots} />}

    <link rel="canonical" href={currentUrl} />

    <link rel="icon" type="image/png" href="/favicon.png" />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />

    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <SchemaJsonLd data={jsonLd} />
  </head>

  <body>
    <header class="site-header">
      <nav class="site-nav">
        <a href="/">Home</a>
        <button
          class="site-search-trigger"
          type="button"
          data-search-modal-trigger
          aria-label="Search public MWE surfaces"
        >
          Search public MWE surfaces
        </button>

        <a href="/about/">About</a>

        <a href="/surfaces/">Entry</a>

        <a href="/atlas/">Atlas</a>

        <a href="/models/">Models</a>

        <a href="/fiction/">Fiction</a>

        <a href="/artistic-research/">Artistic Research</a>

        <a href="/publications/">Publications</a>

        <a href="/ai-readable-knowledge-architecture/">AI Architecture</a>

        <a href="/zh/">中文</a>
      </nav>

      <PublicSearchModal />
    </header>

    <main class={mainClass}>
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        Meta-Writing Ecology is a public-facing orientation surface of a recursive
        linguistic and structural analysis system. This site does not contain the
        full working corpus or a complete applied methodology.
      </p>
    </footer>
  </body>
</html>
