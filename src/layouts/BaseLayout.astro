---
import "../styles/global.css";

const {
  title = "Meta-Writing Ecology",
  description = "A recursive linguistic system and structural diagnostic framework."
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <script
      type="module"
      src="https://66a032cb-79af-46cb-82f1-2576f76bae9d.search.ai.cloudflare.com/assets/v0.0.40/search-snippet.es.js"
    ></script>
  </head>

  <body>
    <header class="site-header">
      <nav class="site-nav">
        <a href="/">Home</a>
        <button
          class="site-search-trigger"
          type="button"
          data-search-modal-trigger
          aria-label="Search public MWE surfaces"
        >
          Search public MWE surfaces
        </button>
        <a href="/about/">About</a>
        <a href="/surfaces/">Entry Surfaces</a>
        <a href="/entry-points/">Entry Points</a>
        <a href="/application-boundary/">Application Boundary</a>
        <a href="/diagnostic-entry-layer/">Diagnostic Entry Layer</a>
        <a href="/atlas/">Atlas</a>
        <a href="/models/">Models</a>
        <a href="/fiction/">Fiction</a>
        <a href="/artistic-research/">Artistic Research</a>
        <a href="/publications/">Publications</a>
        <a href="/platforms/">Platforms</a>
        <a href="/ai-reading-guide/">AI Reading Guide</a>
        <a href="/ai-readable-knowledge-architecture/">AI Architecture</a>
        <a href="/zh/">中文</a>
      </nav>
      <search-modal-snippet
        id="public-mwe-search"
        api-url="https://66a032cb-79af-46cb-82f1-2576f76bae9d.search.ai.cloudflare.com/"
        placeholder="Search public MWE surfaces…"
        max-results="10"
        max-render-results="10"
        show-url="true"
        hide-thumbnails="true"
        theme="auto"
        shortcut="k"
        use-meta-key="true"
      ></search-modal-snippet>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        Meta-Writing Ecology is a public-facing orientation surface of a recursive
        linguistic and structural analysis system. This site does not contain the
        full working corpus or a complete applied methodology.
      </p>
    </footer>
    <script is:inline>
      (() => {
        const openSearchModal = async () => {
          if (!("customElements" in window)) return;

          const modal = document.getElementById("public-mwe-search");
          if (!modal) return;

          await customElements.whenDefined("search-modal-snippet");
          modal.open();
        };

        document.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;

          const trigger = target.closest("[data-search-modal-trigger]");
          if (!trigger) return;

          openSearchModal();
        });
      })();
    </script>
  </body>
</html>
