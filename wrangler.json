{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "metawritingecology-site",
  "main": "dist/_worker.js/index.js",
  "compatibility_date": "2025-12-01",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  }
}
